page {
  background: #faf8f3;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  padding: 32rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #ebe7df;
  border-radius: 16rpx;
  padding: 28rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
}

.muted {
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1.6;
}
