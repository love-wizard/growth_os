page {
  background: #f7f4ee;
  color: #25211c;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 30rpx;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 32rpx 56rpx;
}

.home-page,
.weekly-page,
.archive-page,
.coach-page,
.profile-page,
.setup-page,
.guidance-page,
.invite-page,
.interest-page,
.record-preview-page {
  background: linear-gradient(180deg, #fbfaf7 0%, #f5f1eb 46%, #f8f6f2 100%);
}

.home-page {
  padding-top: 28rpx;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.weekly-page,
.archive-page,
.coach-page,
.profile-page {
  padding-bottom: calc(176rpx + env(safe-area-inset-bottom));
}

.splash-page,
.setup-page,
.guidance-page,
.invite-page,
.record-preview-page {
  padding-top: 28rpx;
}

.splash-card {
  background: linear-gradient(145deg, rgba(246, 255, 250, 0.94) 0%, rgba(225, 241, 232, 0.94) 100%);
  border: 1rpx solid rgba(201, 227, 214, 0.84);
  border-radius: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 22rpx 58rpx rgba(54, 111, 85, 0.1);
  padding: 36rpx 32rpx;
}

.home-header {
  align-items: flex-start;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  box-sizing: border-box;
  display: flex;
  gap: 24rpx;
  justify-content: space-between;
  padding: 12rpx 2rpx 2rpx;
}

.home-header .page-title {
  font-size: 42rpx;
  letter-spacing: 0;
  line-height: 56rpx;
}

.home-header .caption {
  font-weight: 600;
}

.child-switcher {
  color: #6e665d;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 34rpx;
  margin-top: 10rpx;
}

.fanmili-header-icon {
  background: linear-gradient(180deg, #ffffff 0%, #f1e6d4 100%);
  border: 1rpx solid rgba(218, 193, 157, 0.82);
  box-shadow: 0 8rpx 22rpx rgba(99, 77, 49, 0.1);
  height: 68rpx;
  width: 68rpx;
}

.fanmili-head {
  background: linear-gradient(180deg, #fffdf8 0%, #f6e6ca 100%);
  border: 1rpx solid rgba(218, 193, 157, 0.66);
  border-radius: 48% 52% 50% 50%;
  height: 44rpx;
  position: relative;
  width: 38rpx;
}

.fanmili-eye {
  background: #5f5143;
  border-radius: 50%;
  height: 5rpx;
  position: absolute;
  top: 18rpx;
  width: 5rpx;
}

.fanmili-eye-left {
  left: 10rpx;
}

.fanmili-eye-right {
  right: 10rpx;
}

.fanmili-smile {
  border-bottom: 2rpx solid rgba(95, 81, 67, 0.76);
  border-radius: 0 0 12rpx 12rpx;
  bottom: 13rpx;
  height: 6rpx;
  left: 14rpx;
  position: absolute;
  width: 10rpx;
}

.family-mode-panel,
.family-archive-panel {
  background: linear-gradient(145deg, rgba(255, 253, 248, 0.94), rgba(236, 247, 241, 0.9));
  border: 1rpx solid rgba(214, 226, 216, 0.82);
  border-radius: 30rpx;
  box-shadow: 0 20rpx 54rpx rgba(88, 74, 56, 0.055);
  box-sizing: border-box;
  overflow: hidden;
  padding: 30rpx 30rpx 26rpx;
}

.family-mode-topline {
  align-items: flex-start;
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
}

.family-mode-title {
  color: #25211c;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 48rpx;
  margin-top: 4rpx;
}

.family-mode-badge {
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(226, 213, 197, 0.82);
  border-radius: 999rpx;
  color: #3f8f6b;
  flex: 0 0 auto;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 34rpx;
  padding: 8rpx 16rpx;
}

.family-mode-rail {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
  overflow-x: auto;
  padding: 2rpx 0 8rpx;
  position: relative;
  white-space: nowrap;
}

.family-mode-connector {
  background: rgba(201, 227, 214, 0.82);
  height: 2rpx;
  left: 34rpx;
  position: absolute;
  right: 34rpx;
  top: 34rpx;
  z-index: 0;
}

.family-mode-child {
  align-items: center;
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  gap: 8rpx;
  min-width: 92rpx;
  position: relative;
  z-index: 1;
}

.family-mode-avatar {
  align-items: center;
  background: linear-gradient(180deg, #ffffff 0%, #f1e6d4 100%);
  border: 1rpx solid rgba(218, 193, 157, 0.82);
  border-radius: 999rpx;
  box-shadow: 0 8rpx 20rpx rgba(99, 77, 49, 0.08);
  color: #6e665d;
  display: flex;
  font-size: 26rpx;
  font-weight: 750;
  height: 68rpx;
  justify-content: center;
  line-height: 68rpx;
  width: 68rpx;
}

.family-mode-name {
  color: #6e665d;
  font-size: 23rpx;
  font-weight: 650;
  line-height: 32rpx;
  max-width: 108rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.family-mode-note {
  background: rgba(255, 255, 255, 0.58);
  border-radius: 18rpx;
  color: #5f685f;
  font-size: 25rpx;
  line-height: 38rpx;
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
}

.page-heading {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
}

.page > .page-heading {
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(238, 232, 223, 0.82);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(88, 74, 56, 0.07);
  box-sizing: border-box;
  padding: 28rpx;
}

.page-heading > view:last-child {
  flex: 1;
  min-width: 0;
}

.visual-icon {
  align-items: center;
  background: linear-gradient(180deg, #f6fff9 0%, #dbeee5 100%);
  border: 1rpx solid rgba(201, 227, 214, 0.86);
  border-radius: 50%;
  box-sizing: border-box;
  color: #3f8f6b;
  display: flex;
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 700;
  height: 64rpx;
  justify-content: center;
  line-height: 64rpx;
  margin-top: 4rpx;
  width: 64rpx;
}

.card {
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(231, 224, 215, 0.82);
  border-radius: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 44rpx rgba(88, 74, 56, 0.055);
  padding: 32rpx;
}

.section {
  margin-top: 32rpx;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.page-title {
  color: #25211c;
  font-size: 46rpx;
  font-weight: 600;
  line-height: 62rpx;
}

.title {
  color: #25211c;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 48rpx;
}

.subtitle {
  color: #6e665c;
  font-size: 30rpx;
  line-height: 48rpx;
  margin-top: 8rpx;
}

.muted {
  color: #6e665c;
  font-size: 26rpx;
  line-height: 40rpx;
}

.caption {
  color: #9b9185;
  font-size: 24rpx;
  line-height: 36rpx;
}

.icon-text-button {
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(231, 224, 215, 0.72);
  border-radius: 999rpx;
  color: #3f8f6b;
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 600;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0 28rpx;
}

.quote-card {
  background: rgba(255, 255, 255, 0.54);
  border: 1rpx solid rgba(235, 228, 219, 0.62);
  border-radius: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 10rpx 30rpx rgba(80, 66, 48, 0.04);
  overflow: hidden;
  padding: 24rpx 28rpx 26rpx;
  position: relative;
}

.quote-card::before {
  display: none;
}

.quote-topline {
  align-items: center;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.quote-eyebrow {
  background: rgba(228, 243, 236, 0.68);
  border-radius: 999rpx;
  color: #3f8f6b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
  padding: 6rpx 16rpx;
}

.quote-mark {
  color: rgba(215, 168, 110, 0.26);
  font-family: Georgia, serif;
  font-size: 72rpx;
  height: 38rpx;
  line-height: 54rpx;
  margin-top: 8rpx;
}

.quote-text {
  color: #25211c;
  font-size: 29rpx;
  font-weight: 600;
  line-height: 44rpx;
  margin-top: 4rpx;
}

.quote-reflection {
  color: #55635b;
  font-size: 26rpx;
  line-height: 40rpx;
  margin-top: 8rpx;
}

.quote-source {
  color: #a29a90;
  flex: 1;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: right;
}

.quote-reflection-box {
  background: transparent;
  border: 0;
  border-left: 6rpx solid rgba(143, 191, 167, 0.68);
  border-radius: 0;
  margin-top: 18rpx;
  padding: 0 0 0 18rpx;
}

.quote-reflection-label {
  color: #3f8f6b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.home-focus-card {
  background: linear-gradient(145deg, rgba(252, 255, 253, 0.98) 0%, rgba(230, 244, 236, 0.96) 100%);
  border: 1rpx solid rgba(201, 227, 214, 0.7);
  border-radius: 34rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 64rpx rgba(54, 111, 85, 0.1);
  padding: 34rpx 34rpx 32rpx;
  position: relative;
}

.focus-topline {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.focus-minutes {
  background: rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  color: #3f8f6b;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 36rpx;
  padding: 8rpx 18rpx;
}

.focus-title {
  color: #25211c;
  font-size: 38rpx;
  font-weight: 650;
  line-height: 54rpx;
}

.focus-context {
  color: #495c52;
  font-size: 27rpx;
  line-height: 42rpx;
}

.focus-why {
  background: rgba(255, 255, 255, 0.58);
  border: 0;
  border-radius: 20rpx;
  color: #5f685f;
  font-size: 26rpx;
  line-height: 40rpx;
  padding: 22rpx 24rpx;
}

.home-children-overview {
  padding: 30rpx 32rpx;
}

.home-child-card {
  align-items: center;
  background: rgba(255, 253, 248, 0.76);
  border: 1rpx solid rgba(231, 224, 215, 0.62);
  border-radius: 22rpx;
  display: flex;
  gap: 18rpx;
  padding: 20rpx;
}

.home-child-main {
  flex: 1;
  min-width: 0;
}

.home-child-card .progress-pill {
  flex: 0 0 auto;
}

.companionship-insight-card {
  background: rgba(255, 253, 248, 0.82);
  border-color: rgba(226, 213, 197, 0.76);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(88, 74, 56, 0.05);
  padding: 30rpx 32rpx;
}

.insight-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.insight-chip {
  background: rgba(238, 248, 243, 0.92);
  border: 1rpx solid rgba(201, 227, 214, 0.76);
  border-radius: 999rpx;
  color: #3f8f6b;
  font-size: 23rpx;
  font-weight: 650;
  line-height: 34rpx;
  padding: 8rpx 16rpx;
}

.family-action-note {
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(231, 224, 215, 0.7);
  border-radius: 20rpx;
  color: #5f685f;
  font-size: 26rpx;
  line-height: 40rpx;
  padding: 20rpx 22rpx;
}

.home-summary-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
}

.summary-tile {
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(231, 224, 215, 0.66);
  border-radius: 22rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(88, 74, 56, 0.035);
  min-height: 132rpx;
  padding: 22rpx;
}

.summary-title {
  color: #25211c;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 44rpx;
  margin-top: 10rpx;
}

.home-task-card {
  background: rgba(255, 255, 255, 0.76);
  border-color: rgba(231, 224, 215, 0.84);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(88, 74, 56, 0.06);
  padding-bottom: 12rpx;
}

.home-task-header {
  gap: 20rpx;
}

.home-task-header .title {
  flex: 1;
  min-width: 0;
}

.home-task-header .compact-button {
  flex: 0 0 auto;
  margin-left: 0;
  min-width: 184rpx;
}

.weekly-page {
  padding-top: 28rpx;
}

.page-child-selector {
  display: flex;
  gap: 14rpx;
  overflow-x: auto;
  padding-bottom: 2rpx;
  white-space: nowrap;
}

.page-child-chip {
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(231, 224, 215, 0.82);
  border-radius: 999rpx;
  color: #6e665d;
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 40rpx;
  margin: 0;
  min-width: 136rpx;
  padding: 12rpx 22rpx;
}

.page-child-chip::after {
  border: 0;
}

.page-child-chip-active {
  background: rgba(63, 143, 107, 0.12);
  border-color: rgba(63, 143, 107, 0.34);
  color: #2f7f5d;
}

.weekly-hero-card {
  background: linear-gradient(145deg, rgba(246, 250, 255, 0.94) 0%, rgba(231, 239, 250, 0.94) 100%);
  border: 1rpx solid rgba(212, 228, 250, 0.82);
  border-radius: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 22rpx 58rpx rgba(67, 96, 132, 0.1);
  padding: 36rpx 32rpx;
}

.weekly-hero-top {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
}

.weekly-progress-number {
  color: #25211c;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.weekly-progress-pill {
  background: rgba(255, 255, 255, 0.78);
  border-radius: 999rpx;
  color: #527fab;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 36rpx;
  padding: 8rpx 18rpx;
}

.weekly-weekend {
  color: #4f5f68;
  font-size: 29rpx;
  line-height: 46rpx;
  margin-top: 10rpx;
}

.weekly-role-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
}

.role-summary-card {
  border: 1rpx solid rgba(231, 224, 215, 0.72);
  border-radius: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 34rpx rgba(88, 74, 56, 0.045);
  min-height: 132rpx;
  padding: 20rpx 16rpx;
}

.role-summary-father {
  background: rgba(234, 242, 255, 0.78);
}

.role-summary-mother {
  background: rgba(255, 246, 235, 0.82);
}

.role-summary-family,
.role-summary-child {
  background: rgba(236, 247, 241, 0.82);
}

.role-summary-number {
  color: #25211c;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 52rpx;
  margin-top: 8rpx;
}

.weekly-task-section {
  padding-bottom: 8rpx;
}

.weekly-section-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.weekly-group {
  border-top: 1rpx solid rgba(231, 224, 215, 0.76);
  padding: 28rpx 0 8rpx;
}

.weekly-group:first-of-type {
  border-top: 0;
}

.weekly-group-title {
  align-items: center;
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.weekly-task-row {
  align-items: center;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
}

.coach-page {
  padding-top: 28rpx;
}

.coach-ask-card {
  background: linear-gradient(145deg, rgba(255, 252, 247, 0.96) 0%, rgba(242, 250, 246, 0.92) 100%);
  border: 1rpx solid rgba(231, 224, 215, 0.84);
  border-radius: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 22rpx 58rpx rgba(88, 74, 56, 0.08);
  padding: 32rpx;
}

.coach-question-box {
  background: rgba(255, 255, 255, 0.82);
  min-height: 180rpx;
}

.coach-prompt-panel {
  background: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(231, 224, 215, 0.78);
  border-radius: 24rpx;
  padding: 22rpx;
}

.coach-chip-row {
  margin-top: 14rpx;
}

.coach-answer-text {
  white-space: pre-line;
}

.coach-action-list {
  border-top: 1rpx solid rgba(201, 227, 214, 0.9);
}

.coach-empty-history {
  margin-top: 20rpx;
}

.coach-history-note {
  margin-top: 18rpx;
}

.coach-history-card {
  background: rgba(255, 255, 255, 0.58);
  box-shadow: 0 10rpx 30rpx rgba(88, 74, 56, 0.035);
}

.interest-page {
  padding-top: 28rpx;
}

.interest-hero-card {
  background: linear-gradient(145deg, rgba(246, 250, 255, 0.94) 0%, rgba(236, 247, 241, 0.92) 100%);
  border: 1rpx solid rgba(212, 228, 250, 0.78);
  border-radius: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 22rpx 58rpx rgba(67, 96, 132, 0.08);
  padding: 32rpx;
}

.interest-summary-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr 1fr;
}

.interest-summary-grid .summary-tile {
  background: rgba(255, 255, 255, 0.72);
  border-color: rgba(212, 228, 250, 0.76);
  min-height: 128rpx;
  padding: 20rpx 16rpx;
}

.interest-empty {
  margin-top: 20rpx;
}

.guidance-hero-card,
.invite-hero-card {
  background: linear-gradient(145deg, rgba(255, 252, 247, 0.96) 0%, rgba(246, 255, 250, 0.9) 100%);
  border: 1rpx solid rgba(231, 224, 215, 0.84);
  border-radius: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 22rpx 58rpx rgba(88, 74, 56, 0.08);
  padding: 36rpx 32rpx;
}

.guidance-step-row {
  align-items: center;
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(231, 224, 215, 0.78);
  border-radius: 22rpx;
  display: flex;
  gap: 18rpx;
  padding: 20rpx;
}

.guidance-value-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr;
}

.record-preview-card {
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(231, 224, 215, 0.82);
  border-radius: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 44rpx rgba(88, 74, 56, 0.055);
  padding: 24rpx;
}

.record-preview-photo-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(3, 1fr);
}

.record-preview-photo {
  background: #eee8df;
  border-radius: 18rpx;
  height: 150rpx;
  width: 100%;
}

.record-preview-photo-large {
  border-radius: 24rpx;
  grid-column: 1 / -1;
  height: 520rpx;
}

.record-preview-photo-small {
  height: 150rpx;
}

.primary-card {
  background: rgba(236, 247, 241, 0.82);
  border-color: rgba(201, 227, 214, 0.78);
}

.warm-card {
  background: rgba(255, 246, 235, 0.82);
  border-color: rgba(243, 217, 184, 0.78);
}

.skeleton-line {
  background: #e7e0d7;
  border-radius: 999rpx;
  height: 28rpx;
  opacity: 0.75;
  width: 100%;
}

.skeleton-line.short {
  width: 46%;
}

.skeleton-title {
  height: 40rpx;
  width: 72%;
}

.blue-card {
  background: rgba(234, 242, 255, 0.82);
  border-color: rgba(212, 228, 250, 0.78);
}

.button-primary,
.button-secondary {
  align-items: center;
  border-radius: 22rpx;
  box-sizing: border-box;
  display: flex;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  justify-content: center;
  line-height: 88rpx;
  margin: 0;
}

.button-primary {
  background: linear-gradient(180deg, #4c9b78 0%, #347f60 100%);
  box-shadow: 0 10rpx 24rpx rgba(63, 143, 107, 0.2);
  color: #ffffff;
}

.button-secondary {
  background: rgba(255, 255, 255, 0.72);
