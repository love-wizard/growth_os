page {
  background: #f8f6f2;
  color: #25211c;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 30rpx;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 32rpx 56rpx;
}

.home-page {
  padding-top: 28rpx;
}

.splash-page,
.setup-page,
.guidance-page,
.invite-page,
.record-preview-page {
  padding-top: 28rpx;
}

.splash-card {
  background: #e4f3ec;
  border: 1rpx solid #c9e3d6;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 36rpx 32rpx;
}

.home-header {
  align-items: flex-start;
  display: flex;
  gap: 24rpx;
  justify-content: space-between;
}

.page-heading {
  align-items: flex-start;
  display: flex;
  gap: 20rpx;
}

.page-heading > view:last-child {
  flex: 1;
  min-width: 0;
}

.visual-icon {
  align-items: center;
  background: #e4f3ec;
  border: 1rpx solid #c9e3d6;
  border-radius: 50%;
  box-sizing: border-box;
  color: #3f8f6b;
  display: flex;
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 700;
  height: 64rpx;
  justify-content: center;
  line-height: 64rpx;
  margin-top: 4rpx;
  width: 64rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e7e0d7;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 32rpx;
}

.section {
  margin-top: 32rpx;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.page-title {
  color: #25211c;
  font-size: 48rpx;
  font-weight: 600;
  line-height: 64rpx;
}

.title {
  color: #25211c;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 48rpx;
}

.subtitle {
  color: #6e665c;
  font-size: 30rpx;
  line-height: 48rpx;
  margin-top: 8rpx;
}

.muted {
  color: #6e665c;
  font-size: 26rpx;
  line-height: 40rpx;
}

.caption {
  color: #9b9185;
  font-size: 24rpx;
  line-height: 36rpx;
}

.icon-text-button {
  background: #ffffff;
  border: 1rpx solid #e7e0d7;
  border-radius: 999rpx;
  color: #3f8f6b;
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 600;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0 28rpx;
}

.quote-card {
  background: #ffffff;
  border: 1rpx solid #eadfce;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 28rpx 32rpx;
  position: relative;
}

.quote-mark {
  color: #d6b17a;
  font-size: 54rpx;
  height: 40rpx;
  line-height: 40rpx;
}

.quote-text {
  color: #25211c;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 48rpx;
}

.quote-reflection {
  color: #6e665c;
  font-size: 26rpx;
  line-height: 40rpx;
  margin-top: 12rpx;
}

.quote-source {
  color: #9b9185;
  font-size: 24rpx;
  line-height: 34rpx;
  margin-top: 8rpx;
}

.quote-divider {
  background: #f0e8de;
  height: 1rpx;
  margin: 22rpx 0 18rpx;
}

.quote-reflection-label {
  color: #3f8f6b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.home-focus-card {
  background: #e4f3ec;
  border: 1rpx solid #c9e3d6;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 36rpx 32rpx;
}

.focus-topline {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.focus-minutes {
  background: rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  color: #3f8f6b;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 36rpx;
  padding: 8rpx 18rpx;
}

.focus-title {
  color: #25211c;
  font-size: 40rpx;
  font-weight: 650;
  line-height: 56rpx;
}

.focus-context {
  color: #4f5f55;
  font-size: 29rpx;
  line-height: 46rpx;
}

.focus-why {
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid #c9e3d6;
  border-radius: 16rpx;
  color: #5f685f;
  font-size: 26rpx;
  line-height: 40rpx;
  padding: 20rpx 22rpx;
}

.home-summary-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
}

.summary-tile {
  background: #ffffff;
  border: 1rpx solid #e7e0d7;
  border-radius: 16rpx;
  box-sizing: border-box;
  min-height: 148rpx;
  padding: 24rpx;
}

.summary-title {
  color: #25211c;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 44rpx;
  margin-top: 10rpx;
}

.home-task-card {
  padding-bottom: 12rpx;
}

.weekly-page {
  padding-top: 28rpx;
}

.weekly-hero-card {
  background: #eaf2ff;
  border: 1rpx solid #d4e4fa;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 36rpx 32rpx;
}

.weekly-hero-top {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
}

.weekly-progress-number {
  color: #25211c;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.weekly-progress-pill {
  background: rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  color: #5d8ccb;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 36rpx;
  padding: 8rpx 18rpx;
}

.weekly-weekend {
  color: #4f5f68;
  font-size: 29rpx;
  line-height: 46rpx;
  margin-top: 10rpx;
}

.weekly-role-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
}

.role-summary-card {
  border-radius: 16rpx;
  box-sizing: border-box;
  min-height: 132rpx;
  padding: 20rpx 16rpx;
}

.role-summary-father {
  background: #eaf2ff;
}

.role-summary-mother {
  background: #fff0df;
}

.role-summary-family,
.role-summary-child {
  background: #e4f3ec;
}

.role-summary-number {
  color: #25211c;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 52rpx;
  margin-top: 8rpx;
}

.weekly-task-section {
  padding-bottom: 8rpx;
}

.weekly-section-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.weekly-group {
  border-top: 1rpx solid #e7e0d7;
  padding: 28rpx 0 8rpx;
}

.weekly-group:first-of-type {
  border-top: 0;
}

.weekly-group-title {
  align-items: center;
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.weekly-task-row {
  align-items: center;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
}

.coach-page {
  padding-top: 28rpx;
}

.coach-ask-card {
  background: #fff0df;
  border: 1rpx solid #f3d9b8;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 32rpx;
}

.coach-question-box {
  background: rgba(255, 255, 255, 0.76);
  min-height: 180rpx;
}

.coach-prompt-panel {
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid #f3d9b8;
  border-radius: 16rpx;
  padding: 22rpx;
}

.coach-chip-row {
  margin-top: 14rpx;
}

.coach-answer-text {
  white-space: pre-line;
}

.coach-action-list {
  border-top: 1rpx solid rgba(201, 227, 214, 0.9);
}

.coach-empty-history {
  margin-top: 20rpx;
}

.coach-history-note {
  margin-top: 18rpx;
}

.interest-page {
  padding-top: 28rpx;
}

.interest-hero-card {
  background: #eaf2ff;
  border: 1rpx solid #d4e4fa;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 32rpx;
}

.interest-summary-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr 1fr;
}

.interest-summary-grid .summary-tile {
  background: rgba(255, 255, 255, 0.7);
  border-color: #d4e4fa;
  min-height: 128rpx;
  padding: 20rpx 16rpx;
}

.interest-empty {
  margin-top: 20rpx;
}

.guidance-hero-card,
.invite-hero-card {
  background: #fff0df;
  border: 1rpx solid #f3d9b8;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 36rpx 32rpx;
}

.guidance-step-row {
  align-items: center;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid #f3d9b8;
  border-radius: 16rpx;
  display: flex;
  gap: 18rpx;
  padding: 20rpx;
}

.guidance-value-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr;
}

.record-preview-card {
  background: #ffffff;
  border: 1rpx solid #eadfce;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 24rpx;
}

.record-preview-photo-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(3, 1fr);
}

.record-preview-photo {
  background: #f1eee8;
  border-radius: 12rpx;
  height: 150rpx;
  width: 100%;
}

.record-preview-photo-large {
  border-radius: 16rpx;
  grid-column: 1 / -1;
  height: 520rpx;
}

.record-preview-photo-small {
  height: 150rpx;
}

.primary-card {
  background: #e4f3ec;
  border-color: #c9e3d6;
}

.warm-card {
  background: #fff0df;
  border-color: #f3d9b8;
}

.skeleton-line {
  background: #e7e0d7;
  border-radius: 999rpx;
  height: 28rpx;
  opacity: 0.75;
  width: 100%;
}

.skeleton-line.short {
  width: 46%;
}

.skeleton-title {
  height: 40rpx;
  width: 72%;
}

.blue-card {
  background: #eaf2ff;
  border-color: #d4e4fa;
}

.button-primary,
.button-secondary {
  align-items: center;
  border-radius: 16rpx;
  box-sizing: border-box;
  display: flex;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  justify-content: center;
  line-height: 88rpx;
  margin: 0;
}

.button-primary {
  background: #3f8f6b;
  color: #ffffff;
}

.button-secondary {
  background: #f1eee8;
  color: #25211c;
}

.row > .button-primary,
.row > .button-secondary {
  flex: 1;
}

.row > .button-primary + .button-secondary,
.row > .button-secondary + .button-primary {
  margin-left: 20rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  background: #f1eee8;
  border-radius: 16rpx;
  color: #6e665c;
  font-size: 26rpx;
  line-height: 40rpx;
  padding: 12rpx 20rpx;
}

.chip-active {
  background: #e4f3ec;
  color: #3f8f6b;
}

.task-row {
  align-items: center;
  border-top: 1rpx solid #e7e0d7;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
}

.task-row:first-child {
  border-top: 0;
  padding-top: 0;
}

.role-badge {
  border-radius: 14rpx;
  flex: 0 0 auto;
  font-size: 24rpx;
  line-height: 36rpx;
  padding: 8rpx 14rpx;
}

.role-father {
  background: #eaf2ff;
  color: #5d8ccb;
}

.role-mother {
  background: #fff0df;
  color: #b46f32;
}

.role-family {
  background: #e4f3ec;
  color: #3f8f6b;
}

.task-main {
  flex: 1;
  min-width: 0;
}

.task-title {
  color: #25211c;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 42rpx;
}

.progress-pill {
  background: #f1eee8;
  border-radius: 999rpx;
  color: #6e665c;
  flex: 0 0 auto;
  font-size: 24rpx;
  line-height: 36rpx;
  padding: 8rpx 16rpx;
}

.timeline-item {
  border-left: 4rpx solid #e7e0d7;
  padding: 0 0 32rpx 24rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-photo-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.timeline-photo {
  border-radius: 12rpx;
  height: 168rpx;
  width: 168rpx;
}

.archive-page {
  padding-bottom: 148rpx;
}

.archive-timeline-section {
  background: transparent;
}

.timeline-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.archive-filter-panel {
  background: #ffffff;
  border: 1rpx solid #e7e0d7;
  border-radius: 16rpx;
  box-sizing: border-box;
  margin-bottom: 28rpx;
  padding: 24rpx;
}

.archive-timeline-item {
  border-left: 4rpx solid #e7e0d7;
  margin-left: 12rpx;
  padding: 0 0 28rpx 28rpx;
  position: relative;
}

.archive-timeline-item:last-child {
  padding-bottom: 0;
}

.archive-timeline-dot {
  background: #3f8f6b;
  border: 6rpx solid #f8f6f2;
  border-radius: 50%;
  height: 18rpx;
  left: -11rpx;
  position: absolute;
  top: 28rpx;
  width: 18rpx;
}

.archive-record-card {
  background: #ffffff;
  border: 1rpx solid #e7e0d7;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 28rpx;
}

.archive-record-card-with-photo {
  border-color: #eadfce;
  padding-top: 20rpx;
}

.archive-record-photo-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 20rpx;
}

.archive-record-photo {
  background: #f1eee8;
  border-radius: 12rpx;
  height: 150rpx;
  width: 100%;
}

.archive-record-photo-large {
  grid-column: 1 / -1;
  height: 340rpx;
}

.archive-tag-row {
  margin-top: 18rpx;
}

.empty-record-state {
  align-items: flex-start;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 12rpx;
}

.floating-add-button {
  align-items: center;
  background: #3f8f6b;
  border-radius: 50%;
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-shadow: 0 16rpx 40rpx rgba(63, 143, 107, 0.28);
  color: #ffffff;
  display: flex;
  font-size: 52rpx;
  font-weight: 400;
  height: 112rpx;
  justify-content: center;
  line-height: 104rpx;
  margin: 0;
  padding: 0;
  position: fixed;
  right: 32rpx;
  width: 112rpx;
  z-index: 20;
}

.floating-add-button::after {
  border: 0;
}

.modal-backdrop {
  align-items: flex-end;
  background: rgba(37, 33, 28, 0.34);
  bottom: 0;
  box-sizing: border-box;
  display: flex;
  left: 0;
  padding: 32rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  top: 0;
  z-index: 30;
}

.record-composer-sheet {
  background: #fffaf3;
  border: 1rpx solid #f3d9b8;
  border-radius: 16rpx;
  box-sizing: border-box;
  max-height: 88vh;
  overflow-y: auto;
  padding: 32rpx;
  width: 100%;
}

.record-hero-photo {
  border-radius: 16rpx;
  height: 360rpx;
  width: 100%;
}

.input-box {
  background: #ffffff;
  border: 1rpx solid #e7e0d7;
  border-radius: 16rpx;
  box-sizing: border-box;
  color: #25211c;
  font-size: 28rpx;
  line-height: 42rpx;
  min-height: 88rpx;
  padding: 20rpx 24rpx;
  width: 100%;
}

.record-time-row {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
}

.filter-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
  margin: 20rpx 0;
}

.picker-box {
  color: #6e665c;
}

.text-area {
  min-height: 176rpx;
}

.note-box {
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid #c9e3d6;
  border-radius: 16rpx;
  padding: 24rpx;
}

.product-note {
  padding: 28rpx 32rpx;
}

.step-dot-row {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.step-dot {
  background: #e7e0d7;
  border-radius: 999rpx;
  height: 8rpx;
  width: 40rpx;
}

.step-dot-active {
  background: #3f8f6b;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.profile-card {
  padding: 28rpx 32rpx;
}

.profile-page {
  padding-top: 28rpx;
}

.profile-family-card {
  background: #e4f3ec;
  border: 1rpx solid #c9e3d6;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 36rpx 32rpx;
}

.profile-child-name {
  color: #25211c;
  font-size: 42rpx;
  font-weight: 650;
  line-height: 58rpx;
}

.profile-child-meta {
  color: #4f5f55;
  font-size: 28rpx;
  line-height: 44rpx;
  margin-top: 8rpx;
}

.profile-empty-note {
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid #c9e3d6;
  border-radius: 16rpx;
  color: #5f685f;
  font-size: 26rpx;
  line-height: 40rpx;
  padding: 20rpx 22rpx;
}

.profile-login-button {
  margin-top: 24rpx;
}

.profile-action-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr;
}

.profile-privacy-card {
  background: #eaf2ff;
  border: 1rpx solid #d4e4fa;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 32rpx;
}

.dev-tools-card {
  background: #ffffff;
  border: 1rpx dashed #d6b17a;
  border-radius: 16rpx;
  box-sizing: border-box;
  padding: 32rpx;
}

.profile-row {
  gap: 24rpx;
  justify-content: flex-start;
}

.photo-preview-card {
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid #e7e0d7;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx;
}

.selected-photo-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr;
}

.photo-preview,
.timeline-photo {
  background: #f1eee8;
  border-radius: 12rpx;
}

.photo-preview {
  height: 280rpx;
  width: 100%;
}

.small-photo-preview {
  height: 180rpx;
}

.timeline-photo-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.timeline-photo {
  flex: 0 0 auto;
  height: 176rpx;
  width: 176rpx;
}

.compact-button {
  flex: 0 0 auto;
  font-size: 26rpx;
  height: 68rpx;
  line-height: 68rpx;
  min-width: 132rpx;
  padding: 0 24rpx;
}

.reminder-status {
  margin-bottom: 20rpx;
}

.action-row {
  justify-content: flex-start;
  margin-top: 20rpx;
}

.avatar-button {
  align-items: center;
  background: #f1eee8;
  border: 0;
  border-radius: 50%;
  display: flex;
  flex: 0 0 auto;
  height: 112rpx;
  justify-content: center;
  line-height: 112rpx;
  margin: 0;
  overflow: hidden;
  padding: 0;
  width: 112rpx;
}

.avatar-button::after {
  border: 0;
}

.avatar-image {
  height: 112rpx;
  width: 112rpx;
}

.avatar-placeholder {
  color: #3f8f6b;
  font-size: 42rpx;
  font-weight: 600;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.nickname-input {
  color: #25211c;
  font-size: 34rpx;
  font-weight: 600;
  height: 52rpx;
  line-height: 52rpx;
  margin-bottom: 8rpx;
  padding: 0;
}
