<view class="page profile-page">
  <view class="page-heading">
    <view class="visual-icon">家</view>
    <view>
      <view class="caption">我的</view>
      <view class="page-title">家庭成长空间</view>
      <view class="subtitle">照看家庭成员、陪伴设置和隐私边界。</view>
    </view>
  </view>

  <view class="section profile-family-card stack">
    <view class="row">
      <view>
        <view class="caption">孩子档案</view>
        <view class="profile-child-name">{{child.nickname}}</view>
        <view wx:if="{{child.age}}" class="profile-child-meta">{{child.age}}，当前重点是轻量陪伴和习惯建立。</view>
        <view wx:if="{{profileStatus}}" class="profile-child-meta">{{profileStatus}}</view>
      </view>
      <button wx:if="{{setupRequired}}" class="button-secondary compact-button" bindtap="openSetup">创建</button>
    </view>
    <view wx:if="{{child.goals.length}}" class="chip-row">
      <view class="chip chip-active" wx:for="{{child.goals}}" wx:key="*this">{{item}}</view>
    </view>
    <view wx:else class="profile-empty-note">完成首次配置后，这里会展示孩子的年度目标。</view>
  </view>

  <view class="section card profile-card">
    <view class="row profile-row">
      <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{parentProfile.avatarUrl}}" class="avatar-image" src="{{parentProfile.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">{{parentProfile.nicknameInitial}}</view>
      </button>
      <view class="profile-main">
        <view class="caption">{{loginStatus}}</view>
        <input
          class="nickname-input"
          type="nickname"
          placeholder="填写微信昵称"
          value="{{parentProfile.nickname}}"
          bindinput="onNicknameInput"
          bindblur="saveParentProfile"
        />
        <view class="muted">家长身份资料，仅用于家庭空间展示。</view>
      </view>
    </view>
    <button wx:if="{{!isLoggedIn}}" class="button-primary profile-login-button" bindtap="login">微信一键登录</button>
    <button wx:else class="button-secondary profile-login-button" bindtap="logout">退出当前身份</button>
  </view>

  <view class="section card stack">
    <view>
      <view class="title">陪伴设置</view>
      <view class="muted">邀请另一位家长，记录兴趣参与，调整温和提醒。</view>
    </view>
    <view class="profile-action-grid">
      <button class="button-secondary" bindtap="openInvite">邀请家长</button>
      <button class="button-secondary" bindtap="openInterests">兴趣参与</button>
      <button class="button-secondary" bindtap="openSetup">首次配置</button>
    </view>
  </view>

  <view class="section card">
    <view>
      <view class="title">温和提醒</view>
      <view class="muted">只提醒自然陪伴场景，不做连续催促。</view>
      <view wx:if="{{reminderStatus}}" class="muted reminder-status">{{reminderStatus}}</view>
    </view>
    <view class="task-row" wx:for="{{reminders}}" wx:key="type">
      <view class="task-main">
        <view class="task-title">{{item.title}}</view>
        <view class="caption">{{item.description}}</view>
      </view>
      <switch
        checked="{{item.enabled}}"
        color="#3F8F6B"
        data-type="{{item.type}}"
        bindchange="toggleReminder"
      />
    </view>
  </view>

  <view class="section profile-privacy-card">
    <view class="caption">隐私</view>
    <view class="title">成长记录默认仅家庭可见</view>
    <view class="muted">分享卡片只展示你选择的成长瞬间，不公开家庭空间里的其他记录。</view>
  </view>

  <view wx:if="{{showDevTools}}" class="section dev-tools-card stack">
    <view>
      <view class="caption">开发测试</view>
      <view class="title">重走首次引导</view>
      <view class="muted">只清除本机引导和页面缓存，不会删除家庭、孩子、成长记录或周计划。</view>
    </view>
    <button class="button-secondary" bindtap="resetLocalOnboardingState">重置本机引导状态</button>
  </view>
</view>
