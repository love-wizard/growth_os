<view class="page coach-page">
  <view class="coach-hero">
    <view class="coach-hero-visual">
      <view class="coach-hero-glow"></view>
      <image
        class="coach-hero-mascot"
        mode="aspectFit"
        src="/images/mascot/fanmili-25d-default.png"
      />
      <view class="coach-hero-bubble">我来帮你拆成一步</view>
    </view>
    <view class="coach-hero-copy">
      <view class="coach-hero-kicker">饭米粒</view>
      <view class="page-title">把今天的陪伴变具体</view>
      <view class="subtitle">正在结合{{selectedAudienceName}}的成长档案，生成一个适合当下执行的建议。</view>
      <view class="coach-hero-tags">
        <view class="coach-hero-tag">看见当下</view>
        <view class="coach-hero-tag">给出小步骤</view>
      </view>
    </view>
  </view>

  <view wx:if="{{prefillNotice}}" class="section card coach-prefill-card">
    <view class="caption">来自成长档案</view>
    <view class="muted">{{prefillNotice}}</view>
  </view>

  <view wx:if="{{children.length > 1}}" class="section page-child-selector">
    <button
      class="page-child-chip {{selectedScope === 'family' ? 'page-child-chip-active' : ''}}"
      data-scope="family"
      bindtap="chooseAudience"
    >
      全家
    </button>
    <button
      wx:for="{{children}}"
      wx:key="id"
      class="page-child-chip {{selectedScope === 'child' && item.selected ? 'page-child-chip-active' : ''}}"
      data-scope="child"
      data-id="{{item.id}}"
      bindtap="chooseAudience"
    >
      {{item.nickname}}
    </button>
  </view>

  <view class="section coach-ask-card stack">
    <view>
      <view class="caption">先说一个具体场景</view>
      <textarea
        class="input-box coach-question-box"
        placeholder="例如：孩子不想练琴怎么办？今晚只有30分钟可以做什么？"
        value="{{freeQuestion}}"
        maxlength="160"
        bindinput="onQuestionInput"
      />
    </view>

    <view class="coach-prompt-panel">
      <view class="caption">可直接提问</view>
      <view class="chip-row coach-chip-row">
        <view
          class="chip {{selectedPrompt === item ? 'chip-active' : ''}}"
          data-prompt="{{item}}"
          bindtap="selectPrompt"
          wx:for="{{prompts}}"
          wx:key="*this"
        >
          {{item}}
        </view>
      </view>
    </view>

    <button class="button-primary" loading="{{isLoading}}" disabled="{{isLoading}}" bindtap="askCoach">
      生成建议
    </button>
  </view>

  <view wx:if="{{hasAnswer || isLoading || errorMessage}}" class="section card primary-card stack">
    <view wx:if="{{isLoading}}" class="stack">
      <view class="caption">正在结合成长档案</view>
      <view class="skeleton-line skeleton-title"></view>
      <view class="skeleton-line"></view>
      <view class="skeleton-line short"></view>
    </view>

    <block wx:else>
      <view wx:if="{{hasAnswer}}">
        <view class="caption">{{answer.contextLabel}}</view>
        <view class="title">{{answer.title}}</view>
      </view>
      <view wx:if="{{hasAnswer}}" class="muted coach-answer-text">{{answer.text}}</view>
      <view wx:if="{{hasAnswer}}" class="coach-action-list">
        <view class="task-row" wx:for="{{answer.actions}}" wx:key="*this">
          <view class="progress-pill">{{index + 1}}</view>
          <view class="task-main">
            <view class="task-title">{{item}}</view>
          </view>
        </view>
      </view>
      <view wx:if="{{hasAnswer && answer.fallback}}" class="note-box">
        <view class="caption">温和备选</view>
        <view class="muted">{{answer.fallback}}</view>
      </view>
      <view wx:if="{{answer.isWeeklyPlanDraft}}" class="note-box">
        <view class="caption">采用说明</view>
        <view class="muted">{{answer.confirmHint}}</view>
      </view>
      <view wx:if="{{errorMessage}}" class="muted">{{errorMessage}}</view>
      <button
        wx:if="{{answer.weeklyPlanDraftId}}"
        class="button-secondary"
        loading="{{isLoading}}"
        disabled="{{answer.isDraftConfirmed}}"
        bindtap="confirmWeeklyPlanDraft"
      >
        {{answer.confirmLabel}}
      </button>
    </block>
  </view>

  <view class="section card coach-history-card">
    <view class="row">
      <view>
        <view class="caption">最近咨询</view>
        <view class="muted">只显示最近 3 条，方便你接着问。</view>
      </view>
      <view class="caption">{{isHistoryLoading ? '加载中' : ''}}</view>
    </view>
    <view wx:if="{{history.length === 0}}" class="muted coach-empty-history">还没有历史记录，先问一个具体问题。</view>
    <view
      wx:for="{{visibleHistory}}"
      wx:key="id"
      class="task-row coach-history-row"
      data-conversation-id="{{item.id}}"
      bindtap="openHistoryItem"
    >
      <view class="task-main">
        <view class="task-title coach-history-message">{{item.message}}</view>
        <view class="caption coach-history-meta">{{item.modeLabel}} · {{item.createdAtLabel}}</view>
        <view class="muted coach-history-summary">{{item.title}}</view>
      </view>
    </view>
    <view wx:if="{{history.length > visibleHistory.length}}" class="caption coach-history-note">已收起更早咨询，新的问题会优先显示在这里。</view>
  </view>
</view>
