<view class="page archive-page">
  <view class="page-heading">
    <view class="visual-icon">+</view>
    <view>
      <view class="caption">成长档案</view>
      <view class="page-title">记录真实发生的小瞬间</view>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="section card">
    <view class="title">{{errorMessage}}</view>
    <view class="muted">完成首次配置后，就可以记录孩子的真实成长瞬间。</view>
  </view>

  <view wx:if="{{children.length > 1}}" class="section family-archive-panel">
    <view class="family-mode-topline">
      <view>
        <view class="caption">全家时间轴</view>
        <view class="family-mode-title">共同瞬间和单独瞬间都放在一起</view>
      </view>
      <view class="family-mode-badge">{{recordScopeOptions[selectedRecordScopeIndex]}}</view>
    </view>
    <view class="archive-scope-strip">
      <view class="archive-scope-pill {{selectedRecordScopeIndex === 1 ? 'archive-scope-pill-active' : ''}}" bindtap="setFamilyRecordScope">全家时间轴</view>
      <view class="archive-scope-pill {{selectedRecordScopeIndex !== 1 ? 'archive-scope-pill-active' : ''}}" bindtap="setChildRecordScope">当前孩子</view>
    </view>
    <view class="family-mode-rail archive-family-rail">
      <view class="family-mode-child" wx:for="{{children}}" wx:key="id">
        <view class="family-mode-avatar">{{item.avatarText}}</view>
        <view class="family-mode-name">{{item.nickname}}</view>
      </view>
      <view class="family-mode-connector"></view>
    </view>
    <view class="family-mode-note">记录时可以关联多个孩子，分享和报告会保留这个家庭关系。</view>
  </view>

  <view class="section card archive-report-card">
    <view>
      <view class="caption">成长月报</view>
      <view wx:if="{{records.length > 0}}" class="title">把 {{records.length}} 条成长瞬间整理成报告</view>
      <view wx:else class="title">先记录几个瞬间，饭米粒再帮你整理月报</view>
      <view wx:if="{{selectedRecordScopeIndex === 1}}" class="muted">饭米粒会整理共同陪伴和每个孩子被看见的瞬间。</view>
      <view wx:else class="muted">饭米粒会结合成长瞬间、周计划和课程记录，整理本月变化。</view>
    </view>
    <button class="button-secondary compact-button" disabled="{{records.length === 0}}" bindtap="generateMonthlyReport">
      生成月报
    </button>
  </view>

  <view wx:if="{{showAnnualReport}}" class="section card archive-report-card annual-report-card">
    <view>
      <view class="caption">年度家庭报告</view>
      <view wx:if="{{allRecords.length > 0}}" class="title">整理今年的共同瞬间和父母寄语</view>
      <view wx:else class="title">记录积累起来后，饭米粒会生成年度报告</view>
      <view class="muted">包含关键成长瞬间、共同瞬间、能力变化和父母寄语。</view>
    </view>
    <button class="button-secondary compact-button" disabled="{{allRecords.length === 0}}" bindtap="generateAnnualReport">
      去问饭米粒
    </button>
  </view>

  <view class="section archive-timeline-section">
    <view class="timeline-header">
      <view>
        <view class="title">时间轴</view>
        <view class="muted">{{filterStartDate && filterEndDate ? '本月' : '全部已加载'}} · {{records.length}} 条成长瞬间</view>
      </view>
      <view class="row compact-row">
        <button
          class="button-secondary compact-button"
          disabled="{{records.length === 0}}"
          bindtap="startPlayback"
        >
          播放
        </button>
        <picker mode="selector" range="{{recordScopeOptions}}" value="{{selectedRecordScopeIndex}}" bindchange="onRecordScopeChange">
          <view class="button-secondary compact-button">{{recordScopeOptions[selectedRecordScopeIndex]}}</view>
        </picker>
        <button class="button-secondary compact-button" bindtap="toggleFilters">{{isFilterOpen ? '收起筛选' : '筛选'}}</button>
      </view>
    </view>
    <view wx:if="{{isFilterOpen}}" class="archive-filter-panel">
      <view class="filter-grid">
        <picker mode="date" value="{{filterStartDate}}" bindchange="onFilterStartDateChange">
          <view class="input-box picker-box">{{filterStartDate || '开始日期'}}</view>
        </picker>
        <picker mode="date" value="{{filterEndDate}}" bindchange="onFilterEndDateChange">
          <view class="input-box picker-box">{{filterEndDate || '结束日期'}}</view>
        </picker>
        <picker mode="selector" range="{{filterCategoryOptions}}" value="{{selectedFilterCategoryIndex}}" bindchange="onFilterCategoryChange">
          <view class="input-box picker-box">{{filterCategoryOptions[selectedFilterCategoryIndex]}}</view>
        </picker>
        <input class="input-box" placeholder="搜索关键字" value="{{filterKeyword}}" bindinput="onFilterKeywordInput" />
      </view>
      <button class="button-secondary compact-button" bindtap="clearFilters">回到本月</button>
    </view>
    <view wx:if="{{isLoading && !hasRecordData && !errorMessage}}" class="stack">
      <view class="skeleton-line skeleton-title"></view>
      <view class="skeleton-line"></view>
      <view class="skeleton-line short"></view>
    </view>
    <view wx:elif="{{records.length === 0 && hasRecordData && !errorMessage}}" class="empty-record-state">
      <view class="muted">还没有成长记录，先写下今天的一件小事。</view>
      <button class="button-secondary compact-button" bindtap="openRecordComposer">记录一条</button>
    </view>
    <block wx:else>
    <view class="archive-timeline-item" wx:for="{{records}}" wx:key="id">
      <view class="archive-timeline-dot"></view>
      <view
        wx:if="{{item.itemKind === 'report'}}"
        class="archive-record-card archive-report-timeline-card"
        data-id="{{item.sourceId}}"
        bindtap="openReportDetail"
      >
        <view class="archive-record-topline">
          <view class="caption">{{item.dateTimeLabel || item.date}}</view>
          <view class="archive-course-badge">{{item.primaryTag}}</view>
        </view>
        <view class="task-title">{{item.title}}</view>
        <view class="archive-record-text">{{item.text}}</view>
        <view class="muted">{{item.sourceText}}</view>
      </view>
      <view wx:else class="archive-record-card {{item.photoUrls && item.photoUrls.length ? 'archive-record-card-with-photo' : ''}}">
        <view wx:if="{{item.photoUrls && item.photoUrls.length}}" class="archive-record-photo-grid">
          <image
            class="archive-record-photo {{item.photoUrls.length === 1 ? 'archive-record-photo-large' : ''}}"
            wx:for="{{item.photoUrls}}"
            wx:for-item="photoUrl"
            wx:key="photoUrl"
            src="{{photoUrl}}"
            mode="aspectFill"
            lazy-load="{{true}}"
            data-current="{{photoUrl}}"
            data-urls="{{item.photoUrls}}"
            binderror="handleRecordPhotoError"
            bindtap="previewRecordPhoto"
          />
        </view>
        <view class="archive-record-topline">
          <view class="caption">{{item.dateTimeLabel || item.date}}</view>
          <button
            wx:if="{{item.itemKind !== 'course'}}"
            class="archive-record-menu-button"
            data-id="{{item.id}}"
            bindtap="openRecordActions"
          >
            ⋯
          </button>
        </view>
        <view class="archive-meta-badges">
          <view wx:if="{{item.primaryTag && item.itemKind !== 'course'}}" class="archive-primary-tag">
            {{item.primaryTag}}
          </view>
          <view wx:if="{{item.itemKind === 'course'}}" class="archive-course-badge">课程记录</view>
          <view wx:if="{{item.childLabel}}" class="archive-child-label">{{item.childLabel}}</view>
        </view>
        <view wx:if="{{item.itemKind === 'course'}}" class="task-title">{{item.title}}</view>
        <view class="archive-record-text {{item.itemKind !== 'course' ? 'archive-record-text-strong' : ''}}">
          {{item.text}}
        </view>
        <view wx:if="{{item.secondaryTags && item.secondaryTags.length}}" class="chip-row archive-tag-row">
          <view class="chip archive-secondary-chip" wx:for="{{item.secondaryTags}}" wx:for-item="tag" wx:key="tag">
            {{tag}}
          </view>
        </view>
        <view wx:if="{{item.itemKind !== 'course'}}" class="row action-row">
          <button
            class="button-secondary compact-button"
            open-type="share"
            data-id="{{item.id}}"
            data-title="{{item.primaryTag || item.title}}"
            data-text="{{item.text}}"
            data-date="{{item.dateTimeLabel || item.date}}"
            data-image-url="{{item.shareImageUrl || item.photoUrls[0]}}"
            bindtap="prepareShareRecord"
          >
            分享记录
          </button>
        </view>
      </view>
    </view>
    <view wx:if="{{hasRecordData && (hasMoreRecords || allRecords.length > records.length)}}" class="archive-load-more">
      <button
        class="button-secondary archive-load-more-button"
        loading="{{isLoadingMoreRecords}}"
        disabled="{{isLoadingMoreRecords}}"
        bindtap="loadMoreRecords"
      >
        {{hasMoreRecords ? '加载更早记录' : '查看更早记录'}}
      </button>
    </view>
    </block>
  </view>

  <button class="floating-add-button" bindtap="openRecordComposer">+</button>

  <view wx:if="{{isPlaybackOpen}}" class="playback-overlay" catchtouchmove="noop">
    <image
      wx:if="{{playbackCurrentPhotoUrl}}"
      class="playback-background-image"
      src="{{playbackCurrentPhotoUrl}}"
      mode="aspectFill"
    />
    <view class="playback-background-mask"></view>
    <view class="playback-shell">
      <view class="playback-header">
        <view wx:if="{{playbackCounterText}}" class="playback-counter-pin">
          {{playbackCounterText}}
        </view>
      </view>

      <view
        class="playback-stage {{playbackCurrentPhotoUrl ? 'playback-stage-with-photo' : 'playback-stage-text-only'}}"
        catchtap="noop"
      >
        <view wx:if="{{playbackCurrentPhotoUrl}}" class="playback-photo-stage">
          <image class="playback-photo" src="{{playbackCurrentPhotoUrl}}" mode="aspectFit" />
          <view class="playback-photo-scrim"></view>
          <view class="playback-copy-overlay">
            <view class="playback-copy-meta">
              <view wx:if="{{playbackCurrentDate}}" class="playback-date-inline" bindlongpress="closePlayback">
                {{playbackCurrentDate}}
              </view>
              <view
                wx:if="{{playbackCurrentTag || playbackCurrentChildLabel || playbackCurrentFrameLabel}}"
                class="chip-row"
              >
                <view wx:if="{{playbackCurrentTag}}" class="playback-chip playback-chip-primary">
                  {{playbackCurrentTag}}
                </view>
                <view wx:if="{{playbackCurrentChildLabel}}" class="playback-chip">
                  {{playbackCurrentChildLabel}}
                </view>
                <view wx:if="{{playbackCurrentFrameLabel}}" class="playback-chip">
                  {{playbackCurrentFrameLabel}}
                </view>
              </view>
              <view wx:if="{{playbackCurrentTitle}}" class="playback-title">{{playbackCurrentTitle}}</view>
            </view>
            <view wx:if="{{playbackTypedText}}" class="playback-text">
              {{playbackTypedText}}<text wx:if="{{playbackIsTyping}}" class="playback-cursor">|</text>
            </view>
            <view wx:elif="{{!playbackIsTyping}}" class="playback-text playback-text-muted">
              这个瞬间没有补充文字。
            </view>
          </view>
        </view>

        <view wx:else class="playback-text-stage">
          <view class="playback-copy-overlay playback-copy-overlay-text-only">
            <view class="playback-copy-meta">
              <view wx:if="{{playbackCurrentDate}}" class="playback-date-inline" bindlongpress="closePlayback">
                {{playbackCurrentDate}}
              </view>
              <view
                wx:if="{{playbackCurrentTag || playbackCurrentChildLabel || playbackCurrentFrameLabel}}"
                class="chip-row"
              >
                <view wx:if="{{playbackCurrentTag}}" class="playback-chip playback-chip-primary">
                  {{playbackCurrentTag}}
                </view>
                <view wx:if="{{playbackCurrentChildLabel}}" class="playback-chip">
                  {{playbackCurrentChildLabel}}
                </view>
                <view wx:if="{{playbackCurrentFrameLabel}}" class="playback-chip">
                  {{playbackCurrentFrameLabel}}
                </view>
              </view>
              <view wx:if="{{playbackCurrentTitle}}" class="playback-title">{{playbackCurrentTitle}}</view>
            </view>
            <view wx:if="{{playbackTypedText}}" class="playback-text">
              {{playbackTypedText}}<text wx:if="{{playbackIsTyping}}" class="playback-cursor">|</text>
            </view>
            <view wx:elif="{{!playbackIsTyping}}" class="playback-text playback-text-muted">
              这个瞬间没有补充文字。
            </view>
          </view>
        </view>
      </view>

      <view class="playback-actions">
        <button class="button-secondary compact-button playback-action-button" catchtap="skipPlaybackStep">
          {{playbackIsTyping ? '显示全文' : '下一个'}}
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{isRecordComposerOpen}}" class="modal-backdrop" bindtap="closeRecordComposer">
    <view class="record-composer-sheet" catchtap="noop">
      <scroll-view scroll-y class="record-composer-scroll">
        <view class="record-composer-body stack">
          <view class="row">
            <view>
              <view class="caption">成长瞬间</view>
              <view class="title">{{composerMode === 'edit' ? '修正这条成长记录' : '今天有什么值得记下？'}}</view>
            </view>
            <button class="button-secondary compact-button" bindtap="closeRecordComposer">关闭</button>
          </view>
          <view wx:if="{{composerMode === 'edit'}}" class="muted">
            当前仅支持修正文案、日期和类别；照片、时间和关联孩子保持原记录不变。
          </view>
          <textarea class="input-box text-area" placeholder="例如：今天第一次主动练琴20分钟。" value="{{recordText}}" bindinput="onRecordTextInput" />
          <picker mode="selector" range="{{recordCategories}}" value="{{selectedCategoryIndex}}" bindchange="onRecordCategoryChange">
            <view class="input-box picker-box">类别 {{recordCategory}}</view>
          </picker>
          <view wx:if="{{composerMode !== 'edit' && children.length > 1}}" class="record-child-selector">
            <view>
              <view class="caption">关联给</view>
              <view class="muted">默认关联全部孩子。单独瞬间可以点掉不相关的孩子。</view>
            </view>
            <view class="chip-row">
              <button
                wx:for="{{children}}"
                wx:key="id"
                class="child-select-chip {{item.selected ? 'child-select-chip-active' : ''}}"
                data-id="{{item.id}}"
                bindtap="toggleRecordChild"
              >
                {{item.nickname}}
              </button>
            </view>
          </view>
          <view wx:if="{{composerMode !== 'edit'}}" class="record-time-row">
            <picker mode="date" value="{{happenedDate}}" bindchange="onHappenedDateChange">
              <view class="input-box picker-box">日期 {{happenedDate}}</view>
            </picker>
            <picker mode="time" value="{{happenedTime}}" bindchange="onHappenedTimeChange">
              <view class="input-box picker-box">时间 {{happenedTime}}</view>
            </picker>
          </view>
          <view wx:if="{{composerMode === 'edit'}}">
            <picker mode="date" value="{{happenedDate}}" bindchange="onHappenedDateChange">
              <view class="input-box picker-box">日期 {{happenedDate}}</view>
            </picker>
          </view>
          <view wx:if="{{composerMode !== 'edit'}}" class="stack">
            <button class="button-secondary" bindtap="choosePhoto">选择照片（最多3张）</button>
            <view wx:if="{{selectedPhotos.length}}" class="selected-photo-grid">
              <view class="photo-preview-card" wx:for="{{selectedPhotos}}" wx:key="path">
                <image class="photo-preview small-photo-preview" src="{{item.path}}" mode="aspectFill" />
                <view class="row">
                  <view class="muted">{{item.name}}</view>
                  <button class="button-secondary compact-button" data-index="{{index}}" bindtap="removeSelectedPhoto">移除</button>
                </view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="record-composer-footer">
        <button class="button-primary" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" bindtap="addRecord">
          {{composerMode === 'edit' ? '保存修改' : '记录成长瞬间'}}
        </button>
      </view>
    </view>
  </view>
</view>
