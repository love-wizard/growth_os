<view class="page">
  <view class="row">
    <view>
      <view class="caption">成长档案</view>
      <view class="page-title">记录真实发生的小瞬间</view>
    </view>
  </view>

  <view class="section card warm-card stack">
    <view>
      <view class="title">今天有什么值得记下？</view>
      <view class="muted">一句话就可以，也可以顺手附上一张照片。</view>
    </view>
    <textarea class="input-box text-area" placeholder="例如：今天第一次主动练琴20分钟。" value="{{recordText}}" bindinput="onRecordTextInput" />
    <input class="input-box" placeholder="标签，用逗号分隔" value="{{recordTags}}" bindinput="onRecordTagsInput" />
    <view class="stack">
      <button class="button-secondary" bindtap="choosePhoto">选择一张照片</button>
      <view wx:if="{{selectedPhotoPath}}" class="photo-preview-card">
        <image class="photo-preview" src="{{selectedPhotoPath}}" mode="aspectFill" />
        <view class="row">
          <view class="muted">{{selectedPhotoName}}</view>
          <button class="button-secondary compact-button" bindtap="clearPhoto">移除</button>
        </view>
      </view>
    </view>
    <button class="button-primary" loading="{{isSubmitting}}" bindtap="addRecord">记录成长瞬间</button>
  </view>

  <view wx:if="{{errorMessage}}" class="section card">
    <view class="title">{{errorMessage}}</view>
    <view class="muted">完成首次配置后，就可以记录孩子的真实成长瞬间。</view>
  </view>

  <view class="section card">
    <view class="title">时间轴</view>
    <view wx:if="{{records.length === 0 && !errorMessage}}" class="muted">还没有成长记录，先写下今天的一件小事。</view>
    <view class="timeline-item" wx:for="{{records}}" wx:key="id">
      <view class="caption">{{item.date}}</view>
      <view class="task-title">{{item.title}}</view>
      <view class="muted">{{item.text}}</view>
      <view wx:if="{{item.photoUrls && item.photoUrls.length}}" class="timeline-photo-row">
        <image
          class="timeline-photo"
          wx:for="{{item.photoUrls}}"
          wx:for-item="photoUrl"
          wx:key="photoUrl"
          src="{{photoUrl}}"
          mode="aspectFill"
          data-current="{{photoUrl}}"
          data-urls="{{item.photoUrls}}"
          bindtap="previewRecordPhoto"
        />
      </view>
      <view class="chip-row">
        <view class="chip" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="tag">{{tag}}</view>
      </view>
      <view class="row action-row">
        <button
          class="button-secondary compact-button"
          open-type="share"
          data-id="{{item.id}}"
          data-title="{{item.title}}"
          data-text="{{item.text}}"
          data-date="{{item.date}}"
          data-image-url="{{item.shareImageUrl || item.photoUrls[0]}}"
          bindtap="prepareShareRecord"
        >
          分享记录
        </button>
      </view>
    </view>
  </view>
</view>
