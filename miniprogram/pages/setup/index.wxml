<view class="page setup-page">
  <view class="page-heading">
    <view class="visual-icon">启</view>
    <view>
      <view class="caption">孩子档案</view>
      <view class="page-title">设置今天的陪伴方向</view>
      <view class="step-dot-row">
        <view class="step-dot {{step >= 1 ? 'step-dot-active' : ''}}"></view>
        <view class="step-dot {{step >= 2 ? 'step-dot-active' : ''}}"></view>
        <view class="step-dot {{step >= 3 ? 'step-dot-active' : ''}}"></view>
        <view class="step-dot {{step >= 4 ? 'step-dot-active' : ''}}"></view>
      </view>
    </view>
  </view>

  <view wx:if="{{step === 1}}" class="section card stack">
    <view>
      <view class="title">孩子基本信息</view>
      <view class="muted">先用最少信息生成建议，完整目标可以之后再补。</view>
    </view>
    <input class="input-box" placeholder="例如：柚子" value="{{nickname}}" bindinput="onNicknameInput" />
    <picker mode="date" value="{{birthDate}}" bindchange="onBirthDateChange">
      <view class="input-box picker-box">{{birthDate || '选择出生日期'}}</view>
    </picker>
    <view class="chip-row">
      <view class="chip {{gender === 'female' ? 'chip-active' : ''}}" data-value="female" bindtap="chooseGender">女孩</view>
      <view class="chip {{gender === 'male' ? 'chip-active' : ''}}" data-value="male" bindtap="chooseGender">男孩</view>
    </view>
    <button class="button-primary" bindtap="nextStep">下一步</button>
  </view>

  <view wx:if="{{step === 2}}" class="section card stack">
    <view>
      <view class="title">最近想关注什么？</view>
      <view class="muted">选2-3个方向就够了。</view>
    </view>
    <view class="chip-row">
      <view
        class="chip {{item.selected ? 'chip-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="toggleFocus"
        wx:for="{{focusOptions}}"
        wx:key="value"
      >
        {{item.label}}
      </view>
    </view>
    <view class="row">
      <button class="button-secondary" bindtap="prevStep">上一步</button>
      <button class="button-primary" bindtap="nextStep">下一步</button>
    </view>
  </view>

  <view wx:if="{{step === 3}}" class="section card stack">
    <view>
      <view class="title">今天最需要解决什么？</view>
      <view class="muted">饭米粒会围绕这个具体场景给建议。</view>
    </view>
    <view class="chip-row">
      <view
        class="chip {{selectedChallenge === item.value ? 'chip-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="chooseChallenge"
        wx:for="{{challengeOptions}}"
        wx:key="value"
      >
        {{item.label}}
      </view>
    </view>
    <view>
      <view class="title">孩子现在更像哪种状态？</view>
      <view class="muted">选1-3个特质，让建议更贴近孩子。</view>
    </view>
    <view class="chip-row">
      <view
        class="chip {{item.selected ? 'chip-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="toggleTrait"
        wx:for="{{traitOptions}}"
        wx:key="value"
      >
        {{item.label}}
      </view>
    </view>
    <view wx:if="{{suggestionErrorMessage}}" class="muted">{{suggestionErrorMessage}}</view>
    <view class="row">
      <button class="button-secondary" bindtap="prevStep">上一步</button>
      <button class="button-primary" loading="{{isGeneratingSuggestion}}" disabled="{{isGeneratingSuggestion}}" bindtap="nextStep">生成建议</button>
    </view>
  </view>

  <view wx:if="{{step === 4}}" class="section card primary-card stack">
    <view>
      <view class="caption">基于 {{nickname || '孩子'}} / {{suggestion ? suggestion.estimatedMinutes : 15}} 分钟</view>
      <view class="title">{{suggestion ? suggestion.title : '正在准备建议'}}</view>
    </view>
    <view class="chip-row">
      <view class="chip chip-active">{{suggestion ? suggestion.estimatedMinutes : 15}}分钟</view>
      <block wx:for="{{traitOptions}}" wx:key="value">
        <view wx:if="{{item.selected}}" class="chip">{{item.label}}</view>
      </block>
    </view>
    <view class="muted">{{suggestion ? suggestion.childSpecificContext : ''}}</view>
    <view class="title">{{suggestion ? suggestion.action : ''}}</view>
    <view class="muted">{{suggestion ? suggestion.whyItHelps : ''}}</view>
    <view class="muted">{{suggestion ? suggestion.gentleFallback : ''}}</view>
    <view>
      <view class="title">如果加入本周计划，交给谁更合适？</view>
      <view class="muted">建档完成后会用这个归属写进本周计划。</view>
    </view>
    <view class="chip-row">
      <view
        class="chip {{selectedAssignee === item.value ? 'chip-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="chooseAssignee"
        wx:for="{{assigneeOptions}}"
        wx:key="value"
      >
        {{item.label}}
      </view>
    </view>
    <view wx:if="{{suggestionErrorMessage}}" class="muted">{{suggestionErrorMessage}}</view>
    <view class="row">
      <button class="button-secondary" bindtap="prevStep">调整一下</button>
      <button class="button-primary" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" bindtap="saveAndTry">保存后先试试看</button>
    </view>
    <button class="button-secondary" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" bindtap="saveAndAddToWeeklyPlan">保存并加入本周计划</button>
  </view>
</view>
