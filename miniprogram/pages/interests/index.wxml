<view class="page">
  <view class="row">
    <view>
      <view class="caption">兴趣班管理</view>
      <view class="page-title">记录一次真实参与</view>
    </view>
  </view>

  <view class="section card warm-card stack">
    <view>
      <view class="title">今天参加了什么？</view>
      <view class="muted">只记录真实发生的情况，不需要补打卡。</view>
    </view>

    <view wx:if="{{interestOptions.length}}" class="chip-row">
      <view
        wx:for="{{interestOptions}}"
        wx:key="id"
        class="chip {{selectedInterestId === item.id ? 'chip-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="chooseInterest"
      >
        {{item.name}}
      </view>
    </view>
    <view wx:else class="muted">请先在首次配置里补充兴趣方向。</view>

    <input class="input-box" placeholder="日期 YYYY-MM-DD" value="{{happenedOn}}" bindinput="onDateInput" />

    <view class="chip-row">
      <view
        wx:for="{{outcomeOptions}}"
        wx:key="value"
        class="chip {{selectedOutcome === item.value ? 'chip-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="chooseOutcome"
      >
        {{item.label}}
      </view>
    </view>

    <input
      wx:if="{{selectedOutcome === 'completed'}}"
      class="input-box"
      type="number"
      placeholder="时长（分钟）"
      value="{{durationMinutes}}"
      bindinput="onDurationInput"
    />

    <textarea class="input-box text-area" placeholder="备注，例如：今天更主动了，状态不错。" value="{{notes}}" bindinput="onNotesInput" />
    <button class="button-primary" loading="{{isSubmitting}}" bindtap="saveRecord">记录这次参与</button>
  </view>

  <view wx:if="{{errorMessage}}" class="section card">
    <view class="title">{{errorMessage}}</view>
    <view class="muted">先完成首次配置，再记录兴趣班参与情况。</view>
  </view>

  <view class="section card">
    <view class="title">最近记录</view>
    <view wx:if="{{records.length === 0 && !errorMessage}}" class="muted">还没有记录，先记下一次真实参与。</view>
    <view wx:for="{{records}}" wx:key="id" class="task-row interest-row">
      <view class="task-main">
        <view class="task-title">{{item.interestName}}</view>
        <view class="muted">{{item.date}} · {{item.outcomeLabel}}</view>
        <view wx:if="{{item.detail}}" class="caption">{{item.detail}}</view>
      </view>
      <view wx:if="{{item.badge}}" class="progress-pill">{{item.badge}}</view>
    </view>
  </view>
</view>
