<view class="page interest-page">
  <view>
    <view class="caption">兴趣参与</view>
    <view class="page-title">记录真实发生的练习</view>
    <view class="subtitle">只记录已经发生的参与情况，帮助 AI 理解孩子最近的兴趣状态。</view>
  </view>

  <view class="section interest-hero-card stack">
    <view class="row">
      <view>
        <view class="caption">最近一次</view>
        <view class="title">{{summary.latestLabel}}</view>
      </view>
      <view class="progress-pill">{{isLoading ? '加载中' : '已同步'}}</view>
    </view>
    <view class="interest-summary-grid">
      <view class="summary-tile">
        <view class="caption">总记录</view>
        <view class="summary-title">{{summary.totalRecords}}次</view>
      </view>
      <view class="summary-tile">
        <view class="caption">完成参与</view>
        <view class="summary-title">{{summary.completedRecords}}次</view>
      </view>
      <view class="summary-tile">
        <view class="caption">累计时长</view>
        <view class="summary-title">{{summary.totalMinutes}}分钟</view>
      </view>
    </view>
  </view>

  <view class="section card warm-card stack">
    <view>
      <view class="title">记下一次参与</view>
      <view class="muted">可以记录上课、练习、缺席或改期，不需要补打卡。</view>
    </view>

    <view wx:if="{{interestOptions.length}}" class="chip-row">
      <view
        wx:for="{{interestOptions}}"
        wx:key="id"
        class="chip {{selectedInterestId === item.id ? 'chip-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="chooseInterest"
      >
        {{item.name}}
      </view>
    </view>
    <view wx:else class="muted">请先在首次配置里补充兴趣方向。</view>

    <picker mode="date" value="{{happenedOn}}" bindchange="onDateInput">
      <view class="input-box picker-box">日期 {{happenedOn}}</view>
    </picker>

    <view class="chip-row">
      <view
        wx:for="{{outcomeOptions}}"
        wx:key="value"
        class="chip {{selectedOutcome === item.value ? 'chip-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="chooseOutcome"
      >
        {{item.label}}
      </view>
    </view>

    <input
      wx:if="{{selectedOutcome === 'completed'}}"
      class="input-box"
      type="number"
      placeholder="时长（分钟）"
      value="{{durationMinutes}}"
      bindinput="onDurationInput"
    />

    <textarea class="input-box text-area" placeholder="备注，例如：今天更主动了，状态不错。" value="{{notes}}" bindinput="onNotesInput" />
    <button class="button-primary" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" bindtap="saveRecord">记录这次参与</button>
  </view>

  <view wx:if="{{errorMessage}}" class="section card">
    <view class="title">{{errorMessage}}</view>
    <view class="muted">先完成首次配置，再记录兴趣参与情况。</view>
  </view>

  <view class="section card">
    <view class="row">
      <view class="title">最近记录</view>
      <view class="caption">{{isLoading ? '加载中' : ''}}</view>
    </view>
    <view wx:if="{{records.length === 0 && !errorMessage}}" class="muted interest-empty">还没有记录，先记下一次真实参与。</view>
    <view wx:for="{{records}}" wx:key="id" class="task-row interest-row">
      <view class="task-main">
        <view class="task-title">{{item.interestName}}</view>
        <view class="muted">{{item.date}} · {{item.outcomeLabel}}</view>
        <view wx:if="{{item.detail}}" class="caption">{{item.detail}}</view>
      </view>
      <view wx:if="{{item.badge}}" class="progress-pill">{{item.badge}}</view>
    </view>
  </view>
</view>
