<view class="page home-page">
  <view class="home-header">
    <view class="page-heading">
      <view class="visual-icon fanmili-header-icon">
        <view class="fanmili-head">
          <view class="fanmili-eye fanmili-eye-left"></view>
          <view class="fanmili-eye fanmili-eye-right"></view>
          <view class="fanmili-smile"></view>
        </view>
      </view>
      <view>
        <view class="caption">饭米粒在这里</view>
        <view wx:if="{{childNickname}}" class="page-title">今天陪{{childNickname}}慢慢来</view>
        <view wx:else class="page-title">今天我们慢慢来</view>
      </view>
    </view>
    <button class="icon-text-button" bindtap="openArchive">记录</button>
  </view>

  <view class="section quote-card">
    <view class="quote-topline">
      <view class="quote-eyebrow">今日摘录</view>
      <view class="quote-source">{{dailyQuote.source}}</view>
    </view>
    <view class="quote-mark">“</view>
    <view class="quote-text">{{dailyQuote.quote}}</view>
    <view class="quote-reflection-box">
      <view class="quote-reflection-label">饭米粒认为</view>
      <view class="quote-reflection">{{dailyQuote.reflection}}</view>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="section card warm-card stack">
    <view>
      <view class="title">{{errorMessage}}</view>
      <view class="muted">先完成首次配置，系统会生成本周主题和陪伴任务。</view>
    </view>
    <button wx:if="{{setupRequired}}" class="button-primary" bindtap="openSetup">去创建成长系统</button>
  </view>

  <view wx:if="{{isLoading && !hasDashboardData && !errorMessage}}" class="section card primary-card stack">
    <view class="skeleton-line skeleton-title"></view>
    <view class="skeleton-line"></view>
    <view class="skeleton-line short"></view>
  </view>

  <block wx:if="{{hasDashboardData}}">
    <view class="section home-focus-card stack">
      <view class="focus-topline">
        <view class="caption">今天最小行动</view>
        <view class="focus-minutes">{{todayAction.minutes}}</view>
      </view>
      <view class="focus-title">{{todayAction.title}}</view>
      <view class="focus-context">{{todayAction.context}}</view>
      <view class="focus-why">{{todayAction.why}}</view>
      <view class="row">
        <button class="button-primary" bindtap="startAction">记录这个瞬间</button>
        <button class="button-secondary" bindtap="openCoach">问饭米粒</button>
      </view>
    </view>

    <view class="section home-summary-grid">
      <view class="summary-tile">
        <view class="caption">本周主题</view>
        <view class="summary-title">《{{weeklyTheme}}》</view>
      </view>
      <view class="summary-tile">
        <view class="caption">今日任务</view>
        <view class="summary-title">{{taskCount}}</view>
      </view>
    </view>

    <view class="section card home-task-card">
      <view class="row">
        <view class="title">今天可推进</view>
        <button class="button-secondary compact-button" bindtap="startAction">完成后记录</button>
      </view>
      <view class="task-row" wx:for="{{tasks}}" wx:key="title">
        <view class="role-badge {{item.roleClass}}">{{item.role}}</view>
        <view class="task-main">
          <view class="task-title">{{item.title}}</view>
          <view class="caption">慢慢来，不需要补任务</view>
        </view>
        <view class="progress-pill">{{item.progress}}</view>
      </view>
    </view>
  </block>
</view>
