<view class="page">
  <view class="card stack">
    <view>
      <view class="caption">成长记录分享</view>
      <view class="title">{{preview && preview.familyName ? preview.familyName : "成长 OS"}}</view>
      <view class="muted">{{preview && preview.subtitle ? preview.subtitle : "把值得记住的小瞬间，好好记下来。"}}</view>
    </view>

    <view wx:if="{{errorMessage}}" class="note-box">
      <view class="task-title">{{errorMessage}}</view>
      <view class="muted">这条分享暂时打不开。</view>
    </view>

    <view wx:if="{{preview}}" class="stack">
      <view wx:if="{{preview.photoUrls && preview.photoUrls.length}}" class="timeline-photo-row">
        <image
          class="record-hero-photo"
          wx:for="{{preview.photoUrls}}"
          wx:for-item="photoUrl"
          wx:key="photoUrl"
          src="{{photoUrl}}"
          mode="aspectFill"
          data-current="{{photoUrl}}"
          data-urls="{{preview.photoUrls}}"
          bindtap="previewPhoto"
        />
      </view>
      <view class="caption">{{preview.happenedOn}}</view>
      <view class="task-title">{{preview.text}}</view>
    </view>

    <button class="button-primary" bindtap="openGrowthOs">我也来记录孩子成长</button>
  </view>
</view>
