<view class="page record-preview-page">
  <view class="page-heading">
    <view class="visual-icon">照</view>
    <view>
      <view class="caption">成长瞬间</view>
      <view class="page-title">{{preview && preview.familyName ? preview.familyName : "一起记录孩子成长"}}</view>
      <view class="subtitle">{{preview && preview.subtitle ? preview.subtitle : "把值得记住的小瞬间，好好留住。"}}</view>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="section card warm-card stack">
    <view>
      <view class="title">{{errorMessage}}</view>
      <view class="muted">这条分享暂时无法打开，可以先进入饭米粒记录自己的家庭瞬间。</view>
    </view>
    <button class="button-primary" bindtap="openGrowthOs">进入饭米粒</button>
  </view>

  <view wx:if="{{preview}}" class="section record-preview-card stack">
    <view wx:if="{{preview.photoUrls && preview.photoUrls.length}}" class="record-preview-photo-grid">
      <image
        class="record-preview-photo {{index === 0 ? 'record-preview-photo-large' : 'record-preview-photo-small'}}"
        wx:for="{{preview.photoUrls}}"
        wx:for-item="photoUrl"
        wx:key="photoUrl"
        src="{{photoUrl}}"
        mode="aspectFill"
        data-current="{{photoUrl}}"
        data-urls="{{preview.photoUrls}}"
        bindtap="previewPhoto"
      />
    </view>
    <view>
      <view class="caption">{{preview.happenedOn}}</view>
      <view class="title">{{preview.text}}</view>
    </view>
    <button class="button-primary" bindtap="openGrowthOs">我也用饭米粒记录</button>
  </view>
</view>
