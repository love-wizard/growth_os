<view class="page">
  <view class="card stack">
    <view>
      <view class="caption">成长记录分享</view>
      <view class="title">只展示文字摘要</view>
      <view class="muted">不会展示家庭私密照片和视频。</view>
    </view>

    <view wx:if="{{errorMessage}}" class="note-box">
      <view class="task-title">{{errorMessage}}</view>
      <view class="muted">登录并加入家庭空间后，才能查看这条记录摘要。</view>
    </view>

    <view wx:if="{{preview}}" class="stack">
      <view class="caption">{{preview.happenedOn}}</view>
      <view class="task-title">{{preview.text}}</view>
      <view class="chip-row">
        <view class="chip" wx:for="{{preview.tags}}" wx:key="*this">{{item}}</view>
      </view>
    </view>

    <button wx:if="{{!isLoggedIn}}" class="button-primary" bindtap="login">微信登录后查看</button>
    <button wx:if="{{isLoggedIn}}" class="button-secondary" bindtap="openHome">回到首页</button>
  </view>
</view>
