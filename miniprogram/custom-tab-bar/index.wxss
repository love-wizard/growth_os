.custom-tabbar {
  align-items: flex-end;
  background: rgba(255, 255, 255, 0.9);
  border-top: 1rpx solid rgba(231, 224, 215, 0.72);
  bottom: 0;
  box-shadow: 0 -14rpx 42rpx rgba(93, 75, 54, 0.08);
  box-sizing: border-box;
  display: flex;
  height: calc(118rpx + env(safe-area-inset-bottom));
  justify-content: space-around;
  left: 0;
  padding: 12rpx 18rpx calc(12rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 1000;
}

.tabbar-item {
  align-items: center;
  box-sizing: border-box;
  color: #9b9185;
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
  height: 88rpx;
  justify-content: center;
  min-width: 0;
}

.tabbar-item.active {
  color: #3f8f6b;
}

.tabbar-symbol {
  align-items: center;
  background: rgba(248, 246, 242, 0.78);
  border-radius: 50%;
  box-sizing: border-box;
  display: flex;
  font-size: 22rpx;
  font-weight: 700;
  height: 42rpx;
  justify-content: center;
  line-height: 42rpx;
  width: 42rpx;
}

.tabbar-item.active .tabbar-symbol {
  background: #e4f3ec;
}

.tabbar-label,
.center-label {
  font-size: 22rpx;
  font-weight: 600;
  line-height: 28rpx;
  white-space: nowrap;
}

.tabbar-center {
  color: #9a7650;
  flex: 1.08;
  height: 116rpx;
  justify-content: flex-start;
  transform: translateY(-30rpx);
}

.tabbar-center.active {
  color: #3f8f6b;
}

.mascot-button {
  align-items: center;
  background: linear-gradient(180deg, #ffffff 0%, #f3eadb 100%);
  border: 5rpx solid rgba(255, 255, 255, 0.98);
  border-radius: 50%;
  box-shadow: 0 16rpx 36rpx rgba(99, 77, 49, 0.16);
  box-sizing: border-box;
  display: flex;
  height: 92rpx;
  justify-content: center;
  width: 92rpx;
}

.tabbar-center.active .mascot-button {
  box-shadow: 0 14rpx 32rpx rgba(63, 143, 107, 0.24);
}

.mascot-face {
  background: linear-gradient(180deg, #fffaf0 0%, #efd2a5 100%);
  border: 1rpx solid rgba(188, 148, 95, 0.84);
  border-radius: 48% 52% 50% 50%;
  box-shadow: inset 0 -4rpx 8rpx rgba(188, 148, 95, 0.12);
  height: 60rpx;
  position: relative;
  width: 52rpx;
}

.mascot-eye {
  background: #4d4033;
  border-radius: 50%;
  height: 6rpx;
  position: absolute;
  top: 24rpx;
  width: 6rpx;
  z-index: 2;
}

.mascot-eye-ring {
  background: rgba(255, 248, 232, 0.96);
  border: 1rpx solid rgba(181, 140, 88, 0.88);
  border-radius: 50%;
  box-shadow: inset 0 -2rpx 5rpx rgba(181, 140, 88, 0.24);
  height: 17rpx;
  position: absolute;
  top: 18rpx;
  width: 17rpx;
  z-index: 1;
}

.mascot-eye-left {
  left: 15rpx;
}

.mascot-eye-right {
  right: 15rpx;
}

.mascot-eye-ring-right {
  right: 9rpx;
}

.mascot-smile {
  border-bottom: 2rpx solid rgba(77, 64, 51, 0.88);
  border-radius: 0 0 16rpx 16rpx;
  bottom: 19rpx;
  height: 8rpx;
  left: 20rpx;
  position: absolute;
  width: 12rpx;
}

.mascot-cheek {
  background: rgba(213, 137, 104, 0.34);
  border-radius: 50%;
  height: 7rpx;
  position: absolute;
  top: 34rpx;
  width: 8rpx;
}

.mascot-cheek-left {
  left: 8rpx;
}

.mascot-cheek-right {
  right: 8rpx;
}

.center-label {
  margin-top: 2rpx;
}
